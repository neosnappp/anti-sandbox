local hitcount = 0
local totalcount = #readonlytab

for _, fullpath in ipairs(readonlytab) do
    local splitpos = string.find(fullpath, "%.")

    local classname = string.sub(fullpath, 1, splitpos - 1)
    local membername = string.sub(fullpath, splitpos + 1)

    local success = pcall(function()
        local object = Instance.new(classname)
        object[membername] = object[membername]
    end)

    if success then
        hitcount += 1
    end
end

print("readonly dtc score: " .. hitcount .. "/" .. totalcount)